# Codex Hackathon Agent environment variables.
# Copy this file to .env and fill in values as needed.

# ---- LLM Configuration ----
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.3

# ---- Database ----
DATABASE_URL=sqlite:///./data/app.db

# ---- Vector Store ----
CHROMA_PERSIST_DIR=./data/chroma

# ---- App Config ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Optional LangSmith tracing ----
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=codex-hackathon-agent
LANGCHAIN_TRACING_V2=true

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Frontend (if separate) ----
# Next.js API is same-origin under src/frontend/app/api.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Vercel Deployment ----
# Configure these as GitHub Actions secrets for .github/workflows/deploy.yml.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=
